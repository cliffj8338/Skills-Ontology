rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId)
        && request.resource.data.role == 'user';
      allow update: if isOwner(userId)
        && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role);

      allow delete: if isOwner(userId)
        && resource.data.role != 'admin';

      match /verifications/{verificationId} {
        allow read, write: if isOwner(userId);
      }
    }
    match /reports/{reportId} {
      allow read: if resource.data.status == 'active'
        || (isAuth() && request.auth.uid == resource.data.createdBy)
        || isAdmin();
      allow create: if isAuth()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.keys().hasAll(['reportData', 'candidateName', 'createdBy', 'createdAt', 'status'])
        && request.resource.data.reportData is string
        && request.resource.data.reportData.size() <= 500000
        && request.resource.data.candidateName is string
        && request.resource.data.candidateName.size() <= 200
        && request.resource.data.status in ['active', 'draft'];
      allow update: if (isAuth() && request.auth.uid == resource.data.createdBy)
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount', 'lastViewedAt']);
      allow delete: if isAuth() && request.auth.uid == resource.data.createdBy;
    }
    match /report_views/{viewId} {
      allow create: if isAuth()
        && request.resource.data.keys().hasAll(['reportId', 'viewedAt'])
        && request.resource.data.reportId is string
        && request.resource.data.reportId.size() <= 100
        && request.resource.data.viewedAt is timestamp
        && request.resource.data.keys().size() <= 6;
      allow read: if isAuth();
      allow update, delete: if false;
    }
    match /analytics_events/{eventId} {
      allow create: if isAuth()
        && request.resource.data.type is string
        && request.resource.data.type.size() <= 50
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().size() <= 10;
      allow read: if isAuth();
      allow update, delete: if false;
    }
    match /site_analytics/{eventId} {
      allow create: if isAuth()
        && request.resource.data.type is string
        && request.resource.data.type.size() <= 50
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().size() <= 12;
      allow read: if isAdmin();
      allow update, delete: if false;
    }
    match /waitlist/{entryId} {
      allow create: if request.resource.data.email is string
        && request.resource.data.name is string
        && request.resource.data.email.size() <= 254
        && request.resource.data.name.size() <= 100
        && request.resource.data.status == 'waiting'
        && request.resource.data.keys().hasOnly(['email', 'name', 'type', 'status', 'source', 'createdAt', 'position', 'referral'])
        && request.resource.data.keys().size() <= 10
        && request.resource.data.createdAt == request.time;
      allow read: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    match /jobs/{jobId} {
      allow read: if isAuth();
      allow write: if false;
    }
    match /meta/{docId} {
      allow read: if isAuth();
      allow write: if false;
    }
  }
}
