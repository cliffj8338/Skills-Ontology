// Blueprint™ Firestore Rules v2.9 | 2026-04-06
// Changelog:
//   v1.0 | 2026-01-15 | Initial rules
//   v1.1 | 2026-02-01 | work_blueprints subcollection (30-key limit)
//   v1.2 | 2026-02-10 | analytics_events, site_analytics, report_views
//   v1.3 | 2026-02-18 | report read split get/list, share token validation
//   v1.4 | 2026-02-27 | work_blueprints key limit 30 → 50
//   v1.5 | 2026-02-28 | waitlist read split get/list for invite detection
//   v1.6 | 2026-03-04 | comparisons subcollection
//   v1.7 | 2026-03-04 | shared_comparisons collection
//   v1.8 | 2026-03-04 | companyValues subcollection
//   v1.9 | 2026-03-08 | analytics collection (airoi hit tracking)
//   v2.0 | 2026-03-12 | analytics/airoi_public public read+write
//   v2.1 | 2026-03-13 | analytics field validation + key caps
//   v2.2 | 2026-03-15 | galileo_counter collection
//   v2.3 | 2026-03-16 | galileo_counter public write (REST API)
//   v2.4 | 2026-03-16 | analytics/galileo_public page view counter
//   v2.5 | 2026-03-27 | commandcenter collection — admin write, public read (Blueprint)
//   v2.6 | 2026-03-27 | commandcenter/tether — public write allowed
//                        Tether admin dashboard writes stats via REST API
//                        using Blueprint's web API key (no auth context).
//                        Data is non-sensitive: LOC counts, deploy count,
//                        version string, feature count, timestamps. No PII.
//   v2.7 | 2026-03-30 | sampleProfiles collection — admin-only read/write
//                        for master admin editing of demo/sample profiles
//   v2.8 | 2026-04-05 | Explorer Mode support — allow explorerData, profileType,
//                        growthSkills, companyTenures, importStats, contentVisibility,
//                        blindDefaults, linkedinContent, privacyLog, devStats on user docs.
//                        Create rule: allow role 'user' with all standard fields.
//                        Update rule: accept all explorer + standard fields.
//   v2.9 | 2026-04-06 | activities array cap (100 items) on user docs.
//                        Write rate limit: max 1 write per second per user.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPERS ──────────────────────────────────────
    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // ── USERS ────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      allow create: if isOwner(userId)
        && request.resource.data.role == 'user'
        && (!('profile' in request.resource.data) || request.resource.data.profile.keys().size() <= 30)
        && (!('skills' in request.resource.data) || request.resource.data.skills.size() <= 500)
        && (!('purpose' in request.resource.data) || (
          request.resource.data.purpose is string
          && request.resource.data.purpose.size() <= 5000
        ))
        && request.resource.data.keys().size() <= 40;

      allow update: if (isOwner(userId) || isAdmin())
        && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role)
        && (!('skills' in request.resource.data) || request.resource.data.skills.size() <= 500)
        && (!('savedJobs' in request.resource.data) || request.resource.data.savedJobs.size() <= 200)
        && (!('verifications' in request.resource.data) || request.resource.data.verifications.size() <= 1000)
        && (!('applications' in request.resource.data) || request.resource.data.applications.size() <= 500)
        && (!('workHistory' in request.resource.data) || request.resource.data.workHistory.size() <= 100)
        && (!('education' in request.resource.data) || request.resource.data.education.size() <= 50)
        && (!('certifications' in request.resource.data) || request.resource.data.certifications.size() <= 100)
        && (!('values' in request.resource.data) || request.resource.data.values.size() <= 100)
        && (!('outcomes' in request.resource.data) || request.resource.data.outcomes.size() <= 200)
        && (!('purpose' in request.resource.data) || (
          request.resource.data.purpose is string
          && request.resource.data.purpose.size() <= 5000
        ))
        && (!('roles' in request.resource.data) || request.resource.data.roles.size() <= 50)
        && (!('activities' in request.resource.data) || request.resource.data.activities.size() <= 100);

      allow delete: if (isOwner(userId) && resource.data.role != 'admin')
        || isAdmin();

      match /verifications/{verificationId} {
        allow read, write: if isOwner(userId);
      }

      match /work_blueprints/{blueprintId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && request.resource.data.keys().size() <= 50
          && request.resource.data.title is string
          && request.resource.data.title.size() <= 300;
        allow update: if isOwner(userId) && request.resource.data.keys().size() <= 50;
        allow delete: if isOwner(userId);
      }

      match /comparisons/{comparisonId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && request.resource.data.id is string
          && request.resource.data.id.size() <= 64
          && request.resource.data.savedAt is string
          && request.resource.data.blueprintTitle is string
          && request.resource.data.blueprintTitle.size() <= 300
          && request.resource.data.candidateName is string
          && request.resource.data.candidateName.size() <= 200
          && request.resource.data.keys().size() <= 20;
        allow update: if isOwner(userId) && request.resource.data.keys().size() <= 20;
        allow delete: if isOwner(userId);
      }

      match /companyValues/{docId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && request.resource.data.name is string
          && request.resource.data.name.size() <= 200
          && request.resource.data.keys().size() <= 10;
        allow delete: if isOwner(userId);
      }
    }

    // ── REPORTS ──────────────────────────────────────
    match /reports/{reportId} {
      allow get: if (
          resource.data.status == 'active'
          && resource.data.shareToken is string
          && resource.data.shareToken.size() > 0
        )
        || (isAuth() && request.auth.uid == resource.data.createdBy)
        || isAdmin();

      allow list: if isAuth()
        && (request.auth.uid == resource.data.createdBy || isAdmin());

      allow create: if isAuth()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.keys().hasAll(['reportData','candidateName','createdBy','createdAt','status','shareToken'])
        && request.resource.data.reportData is string
        && request.resource.data.reportData.size() <= 500000
        && request.resource.data.candidateName is string
        && request.resource.data.candidateName.size() <= 200
        && request.resource.data.status in ['active','draft']
        && request.resource.data.shareToken is string
        && request.resource.data.shareToken.size() >= 16
        && request.resource.data.shareToken.size() <= 64
        && (!('jobTitle' in request.resource.data) || (
          request.resource.data.jobTitle is string
          && request.resource.data.jobTitle.size() <= 300
        ))
        && (!('company' in request.resource.data) || (
          request.resource.data.company is string
          && request.resource.data.company.size() <= 200
        ))
        && (!('createdByName' in request.resource.data) || (
          request.resource.data.createdByName is string
          && request.resource.data.createdByName.size() <= 200
        ))
        && request.resource.data.keys().size() <= 15;

      allow update: if (isAuth() && request.auth.uid == resource.data.createdBy)
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount','lastViewedAt']);

      allow delete: if isAuth() && request.auth.uid == resource.data.createdBy;
    }

    // ── REPORT VIEWS ─────────────────────────────────
    match /report_views/{viewId} {
      allow create: if isAuth()
        && request.resource.data.keys().hasAll(['reportId','viewedAt'])
        && request.resource.data.reportId is string
        && request.resource.data.reportId.size() <= 100
        && request.resource.data.viewedAt is timestamp
        && request.resource.data.keys().size() <= 6;
      allow read: if isAuth();
      allow update, delete: if false;
    }

    // ── ANALYTICS EVENTS ─────────────────────────────
    match /analytics_events/{eventId} {
      allow create: if isAuth()
        && request.resource.data.type is string
        && request.resource.data.type.size() <= 50
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().size() <= 10;
      allow read: if isAuth();
      allow update, delete: if false;
    }

    // ── SITE ANALYTICS ───────────────────────────────
    match /site_analytics/{eventId} {
      allow create: if isAuth()
        && request.resource.data.type is string
        && request.resource.data.type.size() <= 50
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().size() <= 12;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // ── ANALYTICS (airoi + galileo counters) ─────────
    match /analytics/{docId} {
      allow read: if docId == 'airoi_public' || docId == 'galileo_public' || isAdmin();

      allow create: if (docId == 'airoi_public' || docId == 'galileo_public')
        && request.resource.data.keys().hasOnly(['total','unique']);
      allow update: if (docId == 'airoi_public' || docId == 'galileo_public')
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['total','unique']);

      allow create, update: if docId == 'airoi'
        && request.resource.data.keys().size() <= 8;

      allow delete: if false;
    }

    // ── GALILEO COUNTER ──────────────────────────────
    match /galileo_counter/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // ── WAITLIST ─────────────────────────────────────
    match /waitlist/{entryId} {
      allow create: if request.resource.data.email is string
        && request.resource.data.name is string
        && request.resource.data.email.size() <= 254
        && request.resource.data.name.size() <= 200
        && request.resource.data.status == 'waiting'
        && request.resource.data.keys().hasOnly(['email','name','type','status','source','createdAt','position','referral'])
        && request.resource.data.keys().size() <= 10
        && request.resource.data.createdAt == request.time;
      allow get: if true;
      allow list: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── SHARED COMPARISONS ───────────────────────────
    match /shared_comparisons/{compId} {
      allow get: if true;
      allow list: if false;
      allow create: if isAuth()
        && request.resource.data.sharedBy == request.auth.uid
        && request.resource.data.shareToken is string
        && request.resource.data.shareToken.size() >= 32
        && request.resource.data.shareToken.size() <= 64
        && request.resource.data.id is string
        && request.resource.data.blueprintTitle is string
        && request.resource.data.blueprintTitle.size() <= 300
        && request.resource.data.candidateName is string
        && request.resource.data.candidateName.size() <= 200
        && request.resource.data.keys().size() <= 20;
      allow update: if false;
      allow delete: if isAuth() && request.auth.uid == resource.data.sharedBy;
    }

    // ── SAMPLE PROFILES (admin-only editing) ─────────
    match /sampleProfiles/{profileId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── JOBS ─────────────────────────────────────────
    match /jobs/{jobId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // ── META ─────────────────────────────────────────
    match /meta/{docId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // ── COMMAND CENTER (v2.5 / v2.6 / v2.7) ─────────
    // Stores live project summary snapshots for Build Control dashboard
    // at cliffj8338.github.io/commandcenter.
    //
    // All docs: public read (dashboard is unauthenticated GitHub Pages).
    // All docs: public write with key cap — data is non-sensitive stats only.
    //   blueprint: written by app-core.js syncCommandCenter() via Firebase SDK
    //   tether:    written by commandCenterSync.ts via Firestore REST API
    //   airoi:     written by app-core.js (same as blueprint)
    // No PII stored. Blast radius: counts, version strings, timestamps.
    match /commandcenter/{docId} {
      allow read: if true;
      allow create: if request.resource.data.keys().size() <= 20;
      allow update: if request.resource.data.keys().size() <= 20;
      allow delete: if false;
    }

  }
}
